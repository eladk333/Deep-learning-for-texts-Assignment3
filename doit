#!/usr/bin/env python3
"""
doit - An LLM-powered shell command agent.

Usage:
    doit "list files in my Documents folder"
    doit --model ollama_chat/qwen3:4b "show disk usage"
    doit --model ollama_chat/gemma3:4b "what processes are running"
"""

import argparse
import json
import sys
import os

# Ensure local modules (llm.py, store.py) are found even when run via symlink
sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))

from llm import call_llm, is_dangerous, run_shell, get_active_model
import os

from store import (
    load_history, save_turn,
    load_memory, apply_memory_action,
    format_history_for_prompt, format_memory_for_prompt,
    load_shell_history, format_shell_history_for_prompt,
    load_project_profile, apply_profile_action,
)

SYSTEM_PROMPT_TEMPLATE = """
You are a command-line assistant that translates natural language into bash or zsh shell commands.
You must analyze the user's request and respond ONLY with a valid JSON object.
The JSON object must contain a "type" field and a "content" field, and optionally
an "options" field, a "suggested_command" field, or a "memory_action" field.

Rules for "type":
- "command": the request can be fulfilled with a safe bash/zsh shell command.
  "content" is the shell command.
- "answer": the user is asking a conversational question, greeting you, asking
  for a joke, OR asking "how do I do X" / a non-command question. "content" is
  your reply text. If the answer to a "how do I..." question naturally involves
  a shell command, ALSO include a "suggested_command" field with that command as
  a string. Do not execute it yourself - just suggest it.
- "impossible": the user is asking for something a shell command cannot realistically
  achieve. "content" explains why.
- "clarify": the request is genuinely ambiguous AND the different interpretations
  would lead to meaningfully different commands (e.g. sorting by creation date vs
  access date vs modification date, or an ambiguous target file/folder name).
  "content" is the question to ask the user. Optionally include an "options" field:
  a list of short strings representing the possible choices.
  Do NOT use "clarify" for trivial wording differences that would produce the same
  or near-identical command - only when the choice meaningfully changes the result.

Project profile:
If the user asks to create, update, or delete a profile for the current project folder,
include a "profile_action" field in your response:
{{"action": "set" | "append" | "delete", "content": "the profile text"}}
- "set": creates .doit.md in the current directory, or fully replaces it
- "append": adds content to the existing .doit.md (creates it if missing)
- "delete": removes .doit.md from the current directory
"content" is required for "set" and "append", ignored for "delete".
A response can include both a normal action (type/content) AND a profile_action.
Only include "profile_action" when the user explicitly asks to create/update/delete a profile.

Memory:
Separately from "type", the user may ask you to remember something about them
(a fact, preference, or location) that should persist across sessions - this is
different from conversation history, which is temporary. If the request includes
something worth remembering long-term, include a "memory_action" field:
{{"action": "store" | "update" | "delete", "key": "short_identifier", "value": "the fact to remember"}}
- Use "store" for a new memory, "update" to change an existing one (use the same
  key as before if it exists in STORED MEMORIES below), and "delete" to remove one
  the user no longer wants.
- A single request can BOTH perform an action AND include a memory_action.
- Only include "memory_action" when the user is explicitly stating something to
  remember, or asking to change/forget a previous memory. Do not invent memories.

The user's request may refer to previous turns (e.g. "them", "it", "now sort it",
"do that again", "I meant creation date", "modify it to do y", "execute it",
"run that command"). Use the conversation history below to resolve such references.
In particular, if a previous turn was an "answer" with a "suggested_command", and
the user now says something like "execute it", "run it", or "do that", treat that
suggested_command as the basis.
If the request is self-contained, ignore the history.

Also use STORED MEMORIES below to resolve references to things the user asked you
to remember.

The USER SHELL HISTORY section shows commands the user ran directly in their
terminal (tagged [user]) as well as doit invocations (tagged [doit]). Use this
to understand what the user has been doing, what directory they are in, and to
answer questions like "summarize what I just did" or "why did that fail". The
current working directory is shown at the top of that section — use it when
the user refers to "here", "this folder", "this directory", etc.

--- PROJECT PROFILE (current folder context) ---
{project_profile}
--- END PROJECT PROFILE ---

--- STORED MEMORIES ---
{memory_text}
--- END STORED MEMORIES ---

--- USER SHELL HISTORY (most recent last) ---
{shell_history_text}
--- END SHELL HISTORY ---

--- DOIT CONVERSATION HISTORY (most recent last) ---
{history_text}
--- END HISTORY ---

Examples:
User: list files in documents
{{"type": "command", "content": "ls ~/Documents"}}

User: tell me a joke
{{"type": "answer", "content": "Why do programmers wear glasses? Because they can't C#."}}

User: how do I find all python files in this folder?
{{"type": "answer", "content": "You can use find to search for files by extension.", "suggested_command": "find . -name '*.py'"}}

User: list the files in my home folder sorted by date
{{"type": "clarify", "content": "Do you want to sort by:", "options": ["creation date", "access date", "modification date"]}}

User: move to ~/school/llms/ass3, this is my llm class project folder
{{"type": "command", "content": "cd ~/school/llms/ass3", "memory_action": {{"action": "store", "key": "llm_class_project_folder", "value": "~/school/llms/ass3"}}}}

User: create a profile for this project, it's a Python deep learning project and we always use pytest
{{"type": "answer", "content": "Profile created.", "profile_action": {{"action": "set", "content": "This is a Python deep learning project.\n- Always use pytest for testing\n- Prefer python3 over python"}}}}

User: add to this project's profile that we never delete .py files
{{"type": "answer", "content": "Added to profile.", "profile_action": {{"action": "append", "content": "- Never delete .py files without explicit confirmation"}}}}

Respond strictly with the raw JSON object. Do not include markdown formatting or backticks.
"""


def build_system_prompt(history: list, memory: dict, shell_history: list[str], cwd: str, project_profile: str) -> str:
    return SYSTEM_PROMPT_TEMPLATE.format(
        history_text=format_history_for_prompt(history),
        memory_text=format_memory_for_prompt(memory),
        shell_history_text=format_shell_history_for_prompt(shell_history, cwd),
        project_profile=project_profile or "(no project profile found — user can create one with: doit \"create a profile for this project\")",
    )


def main():
    parser = argparse.ArgumentParser(
        description="doit — execute shell commands via natural language",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            '  doit "list files in my home folder"\n'
            '  doit --model ollama_chat/qwen3:4b "show disk usage"\n'
            '  doit --model ollama_chat/gemma3:4b "what processes are running"\n'
        ),
    )
    parser.add_argument("instruction", nargs="+", help="Natural language instruction")
    parser.add_argument(
        "--model", "-m",
        default=None,
        help="LiteLLM model name (overrides ~/doit.cfg)",
    )
    parser.add_argument(
        "--shell", "-s",
        default="/bin/bash",
        help="Shell to use for execution (default: /bin/bash)",
    )
    parser.add_argument(
        "--session",
        default=None,
        help=(
            "Load history from a specific session ID instead of the current one. "
            "Useful for cross-window references. Writes still go to the current session."
        ),
    )

    args = parser.parse_args()
    user_instruction = " ".join(args.instruction)
    model = args.model or get_active_model()
    shell = args.shell

    history = load_history(args.session)
    memory = load_memory()
    shell_history = load_shell_history()
    cwd = os.getcwd()
    project_profile = load_project_profile(cwd)
    system_prompt = build_system_prompt(history, memory, shell_history, cwd, project_profile)

    # --- First LLM call ---
    try:
        parsed = call_llm(model, system_prompt, user_instruction)
    except json.JSONDecodeError:
        print(f"doit: model ({model}) returned invalid JSON.", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"doit: LLM error: {e}", file=sys.stderr)
        sys.exit(1)

    response_type = parsed.get("type")
    content = parsed.get("content")
    memory_action = parsed.get("memory_action")
    profile_action = parsed.get("profile_action")

    if memory_action:
        memory = apply_memory_action(memory, memory_action)
    if profile_action:
        apply_profile_action(cwd, profile_action)

    # --- Clarification loop ---
    if response_type == "clarify":
        print(content)
        options = parsed.get("options")
        if options:
            for i, opt in enumerate(options, start=1):
                print(f"{i}. {opt}")

        try:
            answer = input("> ").strip()
        except EOFError:
            answer = ""

        if not answer:
            print("No answer given, aborting.")
            save_turn({
                "instruction": user_instruction,
                "type": "clarify",
                "content": content,
                "clarification_answer": None,
            })
            return

        if options:
            try:
                idx = int(answer)
                if 1 <= idx <= len(options):
                    answer = options[idx - 1]
            except ValueError:
                pass

        follow_up = (
            f'Original request: "{user_instruction}"\n'
            f'Clarifying question asked: "{content}"\n'
            f'User\'s answer: "{answer}"\n'
            f"Now produce the final response for the original request, "
            f"incorporating the user's answer. Do not ask another clarifying "
            f"question for the same issue."
        )

        try:
            parsed = call_llm(model, system_prompt, follow_up)
        except Exception as e:
            print(f"doit: LLM error: {e}", file=sys.stderr)
            sys.exit(1)

        response_type = parsed.get("type")
        content = parsed.get("content")
        memory_action = parsed.get("memory_action")
        profile_action = parsed.get("profile_action")
        if memory_action:
            memory = apply_memory_action(memory, memory_action)
        if profile_action:
            apply_profile_action(cwd, profile_action)

    # --- Build turn record ---
    turn_record = {
        "instruction": user_instruction,
        "type": response_type,
        "content": content,
    }
    if memory_action:
        turn_record["memory_action"] = memory_action

    # --- Dispatch on response type ---
    if response_type == "command":
        print(content)
        print()

        try:
            dangerous, explanation = is_dangerous(content, model)
        except Exception:
            dangerous, explanation = True, "(safety check failed; treating as dangerous)"

        if dangerous:
            print("This command may modify your filesystem.")
            if explanation:
                print(f"What it does: {explanation}")
            try:
                answer = input("Proceed? [y/N] ").strip().lower()
            except EOFError:
                answer = ""
            if answer != "y":
                print("Aborted.")
                turn_record.update({"command": content, "stdout": "", "stderr": "(aborted by user)"})
                save_turn(turn_record)
                return

        result = run_shell(content, shell)
        if result["stdout"]:
            print(result["stdout"].strip())
        if result["stderr"]:
            print(result["stderr"].strip(), file=sys.stderr)

        turn_record.update({
            "command": content,
            "stdout": result["stdout"],
            "stderr": result["stderr"],
        })

    elif response_type in ("answer", "impossible"):
        print(content)
        suggested = parsed.get("suggested_command")
        if suggested:
            print()
            print(f"Suggested command (not executed): {suggested}")
            turn_record["suggested_command"] = suggested

    save_turn(turn_record)


if __name__ == "__main__":
    main()
